	(text "S2 (Sprechen) pressed = talk: P4-R1(2.2k)-P3.   Coil P1-P4 (Tuerruf DC pulls K1 in);  listen: P2 -> S1 released -> K1_COM -> NO -> P4 -> C1 -> LS1."
		(exclude_from_sim no)
		(at 19.812 175.926 0)
		(effects
			(font
				(size 1.4 1.4)
			)
			(justify left)
		)
		(uuid "053ceec9-0097-4c85-87d1-871b131bea62")
	)
	(text "  P4 line 4 = Tuerruf ring (~12V DC); C1/R1/coil/NO junction.  Ring DC -> coil to P1;  ring tone -> C1 -> LS1 (gong)"
		(exclude_from_sim no)
		(at 19.812 169.926 0)
		(effects
			(font
				(size 1.4 1.4)
			)
			(justify left)
		)
		(uuid "1e5045d3-9ec5-4403-9de9-f5c6803daa6e")
	)
	(text "5-wire bus toward TV20/S central unit:  J1.1..5 = lines P1..P5  (P1-P4 direct bus conductors; line 5/P5 reaches the bus via the external Etagenruf button ET, not on this sheet)"
		(exclude_from_sim no)
		(at 19.812 157.926 0)
		(effects
			(font
				(size 1.4 1.4)
			)
			(justify left)
		)
		(uuid "21f6b41f-e585-4fde-824a-3039f3fba9f6")
	)
	(text "  P1 line 1 = common / reference (speech + ring return; LS1 & coil return)"
		(exclude_from_sim no)
		(at 19.812 160.926 0)
		(effects
			(font
				(size 1.4 1.4)
			)
			(justify left)
		)
		(uuid "2a57105e-815a-45c7-8bd7-28f1344b7296")
	)
	(text "  P5 line 5 = Etagenruf floor-call + speaker LS1 (+ C1) - reaches bus/TV20S via external ET button (Etagenruftaster, not on this sheet)"
		(exclude_from_sim no)
		(at 19.812 172.926 0)
		(effects
			(font
				(size 1.4 1.4)
			)
			(justify left)
		)
		(uuid "7496bc14-ff57-4056-b95b-98bfded7b628")
	)
	(text "Note: S1 and S2 share a footprint but are mounted in opposite orientations on the PCB."
		(exclude_from_sim no)
		(at 19.812 181.926 0)
		(effects
			(font
				(size 1.4 1.4)
			)
			(justify left)
		)
		(uuid "76a5f8ad-4070-4be1-9d76-25f4989c239a")
	)
	(text "S1 (Tueroeffner) pressed: P2-P3 direct door-release bridge (no resistor).   Released: P2-K1_COM."
		(exclude_from_sim no)
		(at 19.812 178.926 0)
		(effects
			(font
				(size 1.4 1.4)
			)
			(justify left)
		)
		(uuid "909ac970-2ac9-4f36-bd35-a17fe5d4c4f9")
	)
	(text "  P2 line 2 = listen down-audio + OeT door-opener pair; common of S1 (Tueroeffner)"
		(exclude_from_sim no)
		(at 19.812 163.926 0)
		(effects
			(font
				(size 1.4 1.4)
			)
			(justify left)
		)
		(uuid "ce642a2d-a11a-4fa4-a885-f7813564e361")
	)
	(text "  P3 line 3 = talk up-audio + OeT door-opener pair; S2 (Sprechen) pressed ties P4-R1(2.2k)-P3"
		(exclude_from_sim no)
		(at 19.812 166.926 0)
		(effects
			(font
				(size 1.4 1.4)
			)
			(justify left)
		)
		(uuid "e5c0791c-dc61-4ffe-a96a-7dabe987ff94")
	)
	(text "WF26/G intercom handset - internal wiring (reverse-engineered)"
